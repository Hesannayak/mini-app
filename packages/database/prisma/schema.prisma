generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  phone_encrypted  String   // Encrypted with AWS KMS
  phone_hash       String   @unique // SHA-256 for lookups
  name             String?
  language         String   @default("hi") // hi, ta, te, en
  permission_level Int      @default(1) // 1-4
  mini_score       Int      @default(0) // 0-100
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  transactions     Transaction[]
  bills            Bill[]
  score_history    MiniScoreHistory[]
  budgets          Budget[]
  savings_goals    SavingsGoal[]
  contacts         UserContact[]
  voice_sessions   VoiceSession[]

  @@map("users")
}

model Transaction {
  id          String   @id @default(uuid())
  user_id     String
  amount      Decimal  @db.Decimal(12, 2)
  type        String   // debit, credit
  category    String   @default("other")
  merchant    String?
  description String?
  source      String   // upi, sms, account_aggregator
  upi_ref_id  String?
  raw_sms     String?  // Deleted after 30 days
  timestamp   DateTime
  created_at  DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, timestamp])
  @@index([user_id, category])
  @@map("transactions")
}

model Bill {
  id           String    @id @default(uuid())
  user_id      String
  biller_id    String    // BBPS biller ID
  biller_name  String
  bill_type    String
  amount       Decimal?  @db.Decimal(12, 2)
  due_date     DateTime?
  status       String    @default("pending") // pending, paid, overdue
  is_recurring Boolean   @default(true)
  last_paid_at DateTime?
  remind_days  Int[]     @default([7, 3, 1])
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, status])
  @@index([user_id, due_date])
  @@map("bills")
}

model MiniScoreHistory {
  id               String   @id @default(uuid())
  user_id          String
  score            Int
  bill_discipline  Int      // Component: 30% weight
  spending_control Int      // Component: 25% weight
  savings_rate     Int      // Component: 25% weight
  income_stability Int      // Component: 20% weight
  explanation      String?
  week_start       DateTime
  created_at       DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, week_start])
  @@map("mini_score_history")
}

model Budget {
  id          String   @id @default(uuid())
  user_id     String
  category    String
  amount      Decimal  @db.Decimal(12, 2)
  month       String   // YYYY-MM format
  spent       Decimal  @default(0) @db.Decimal(12, 2)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, category, month])
  @@map("budgets")
}

model SavingsGoal {
  id            String    @id @default(uuid())
  user_id       String
  name          String
  target_amount Decimal   @db.Decimal(12, 2)
  saved_amount  Decimal   @default(0) @db.Decimal(12, 2)
  target_date   DateTime?
  is_completed  Boolean   @default(false)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("savings_goals")
}

model UserContact {
  id               String   @id @default(uuid())
  user_id          String
  name             String
  alias            String?  // "Maa", "Amma"
  upi_id_encrypted String   // Encrypted with AWS KMS
  is_trusted       Boolean  @default(false)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("user_contacts")
}

model VoiceSession {
  id            String   @id @default(uuid())
  user_id       String
  intent        String
  confidence    Float
  transcript    String?  // Deleted after 30 days
  response_text String
  latency_ms    Int
  created_at    DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at])
  @@map("voice_sessions")
}
